# Database
POSTGRES_DB=blastcrates
POSTGRES_USER=blastcrates
POSTGRES_PASSWORD=blastcrates_secret
DATABASE_URL=postgresql://blastcrates:blastcrates_secret@localhost:5432/blastcrates

# Redis
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379

# JWT
JWT_SECRET=super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=blastcrates_bot

# Admin
ADMIN_IDS=123456789,987654321

# App URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=blastcrates_bot

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Economy
DAILY_REWARD_BASE=100
REFERRAL_REWARD=500
STARTING_BALANCE=1000
